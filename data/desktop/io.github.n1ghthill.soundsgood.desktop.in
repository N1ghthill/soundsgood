[Desktop Entry]
Name=SoundsGood
Name[pt_BR]=SoundsGood
Comment=Play and organize your music collection
Comment[pt_BR]=Reproduza e organize sua coleção de música
Exec=soundsgood %U
Icon=io.github.n1ghthill.soundsgood
Terminal=false
Type=Application
Categories=AudioVideo;Audio;Music;Player;
StartupNotify=true
MimeType=audio/mpeg;audio/flac;audio/ogg;audio/wav;audio/mp4;audio/aac;audio/x-ms-wma;audio/opus;audio/x-aiff;audio/x-mpegurl;audio/x-scpls;
