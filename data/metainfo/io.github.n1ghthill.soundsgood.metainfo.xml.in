  <releases>
    <release version="0.2.3" date="2026-07-19">
      <description>
        <p>Makes persistent playlists reliable for daily use with searchable multi-song selection, direct deletion, stable in-place editing, coalesced atomic saves, and stress-tested recovery.</p>
      </description>
    </release>
    <release version="0.2.2" date="2026-07-19">
      <description>
        <p>Restores album thumbnails and song rows in artist details and adds a regression check for translation aliases used by GTK factories.</p>
      </description>
    </release>
    <release version="0.2.1" date="2026-07-19">
      <description>
        <p>Adds native contextual playlist submenus to songs and albums, direct playlist creation, and safe handling for recycled list rows.</p>
      </description>
    </release>
    <release version="0.2.0" date="2026-07-19">
      <description>
        <p>Adds persistent playlists with atomic storage, playlist import and export, missing-file handling, and adaptive management controls.</p>
      </description>
    </release>
    <release version="0.1.8" date="2026-07-19">
      <description>
        <p>Adds background playback, an optional system tray indicator, virtualized album and artist detail lists, and stricter playback lifecycle cleanup.</p>
      </description>
    </release>
    <release version="0.1.7" date="2026-07-19">
      <description>
        <p>Introduces a compact adaptive player bar, smaller controls, and polished responsive navigation.</p>
      </description>
    </release>
    <release version="0.1.6" date="2026-07-07"/>
    <release version="0.1.5" date="2026-07-07"/>
    <release version="0.1.4" date="2026-07-07"/>
