<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>io.github.n1ghthill.soundsgood</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-2.0-or-later</project_license>
  <name>SoundsGood</name>
  <developer id="io.github.n1ghthill">
    <name>SoundsGood Developers</name>
  </developer>
  <summary>Play and organize your music collection</summary>
  <description>
    <p>A simple and fast music player for Linux. Browse your music by album or artist, play songs, manage the current playback queue, and create persistent playlists with searchable library selection.</p>
  </description>
  <categories>
    <category>AudioVideo</category>
    <category>Audio</category>
    <category>Music</category>
    <category>Player</category>
  </categories>
  <url type="homepage">https://github.com/N1ghthill/soundsgood</url>
  <url type="bugtracker">https://github.com/N1ghthill/soundsgood/issues</url>
  <launchable type="desktop-id">io.github.n1ghthill.soundsgood.desktop</launchable>
  <screenshots>
    <screenshot type="default">
      <caption>Main library view</caption>
      <image>https://raw.githubusercontent.com/N1ghthill/soundsgood/v0.1.8/data/screenshots/soundsgood-main.png</image>
    </screenshot>
    <screenshot>
      <caption>Album grid</caption>
      <image>https://raw.githubusercontent.com/N1ghthill/soundsgood/v0.1.8/docs/screenshots/albums.png</image>
    </screenshot>
    <screenshot>
      <caption>Artists view</caption>
      <image>https://raw.githubusercontent.com/N1ghthill/soundsgood/v0.1.8/docs/screenshots/artists.png</image>
    </screenshot>
    <screenshot>
      <caption>Songs view</caption>
