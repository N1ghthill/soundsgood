<?xml version="1.0" encoding="utf-8"?>
<schemalist>
  <enum id="io.github.n1ghthill.soundsgood.RepeatMode">
    <value value="0" nick="none"/>
    <value value="1" nick="song"/>
    <value value="2" nick="all"/>
    <value value="3" nick="shuffle"/>
  </enum>

  <schema id="io.github.n1ghthill.soundsgood" path="/io/github/n1ghthill/soundsgood/">
    <key name="repeat" enum="io.github.n1ghthill.soundsgood.RepeatMode">
      <default>'none'</default>
      <summary>Repeat mode</summary>
      <description>The repeat mode of the player</description>
    </key>
    <key name="volume" type="d">
      <range min="0.0" max="1.0"/>
      <default>1.0</default>
      <summary>Volume</summary>
      <description>The volume of the player</description>
    </key>
    <key name="mute" type="b">
      <default>false</default>
      <summary>Mute</summary>
      <description>Whether the player is muted</description>
    </key>
    <key name="window-width" type="i">
      <default>1200</default>
      <summary>Window width</summary>
      <description>The width of the main window</description>
    </key>
    <key name="window-height" type="i">
      <default>800</default>
      <summary>Window height</summary>
      <description>The height of the main window</description>
    </key>
    <key name="window-maximized" type="b">
      <default>false</default>
      <summary>Window maximized</summary>
      <description>Whether the window is maximized</description>
    </key>
    <key name="music-dir" type="s">
      <default>''</default>
      <summary>Music directory</summary>
      <description>The directory to scan for music files</description>
    </key>
    <key name="color-scheme" type="s">
      <choices>
        <choice value="system"/>
        <choice value="light"/>
        <choice value="dark"/>
      </choices>
      <default>'system'</default>
      <summary>Color scheme</summary>
      <description>The application color scheme selected by the user</description>
    </key>
    <key name="enable-notifications" type="b">
      <default>true</default>
      <summary>Track notifications</summary>
      <description>Whether to show a desktop notification when a new song starts</description>
    </key>
    <key name="inhibit-suspend" type="b">
      <default>true</default>
      <summary>Prevent suspend while playing</summary>
      <description>Whether to inhibit session suspend while music is playing</description>
    </key>
    <key name="run-in-background" type="b">
      <default>true</default>
      <summary>Run in background</summary>
      <description>Whether closing the main window keeps SoundsGood running in the background</description>
    </key>
  </schema>

</schemalist>
